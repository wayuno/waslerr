# Set these in Railway → Variables. The frontend reads the public ones via the
# backend's /api/config endpoint, so no VITE_ prefix is needed.

# The one email allowed to be admin (must match the account you sign in with).
ADMIN_EMAIL=you@yourdomain.com

# Admin password. On boot the server creates/updates this admin user in
# Supabase Auth, so ADMIN_EMAIL + ADMIN_PASSWORD become the admin login.
ADMIN_PASSWORD=a-strong-admin-password

# Supabase project — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # secret — server only

# PORT is provided automatically by Railway; only needed locally.
PORT=8787
