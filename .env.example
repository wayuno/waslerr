# Server-side admin auth. Set these in Railway → Variables (NOT VITE_ prefixed,
# so they never ship in the client bundle). Copy to a local .env for dev.

# The one email allowed to be admin.
ADMIN_EMAIL=admin@waslerrfields.com

# Secret admin password — required to unlock the dashboard. Make it strong.
ADMIN_PASSWORD=change-this-to-a-strong-password

# Long random string used to sign admin session tokens.
JWT_SECRET=replace-with-a-long-random-string

# PORT is provided automatically by Railway; only needed locally.
PORT=8787
